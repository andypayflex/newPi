AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-01

# Pi model ID to use by default. This should be a model ID Pi knows.
PI_DEFAULT_MODEL=gpt-4.1

# Map Pi model IDs to your Azure deployment names.
# Format: model-id=deployment-name,model-id-2=deployment-name-2
AZURE_OPENAI_DEPLOYMENT_NAME_MAP=gpt-4.1=my-gpt-4-1-deployment
